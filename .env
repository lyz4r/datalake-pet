# Copy this file to .env and fill in real secrets before running `docker compose up`

# -- Postgres (Airflow + Superset metadata) --
POSTGRES_PASSWORD=airflow

# -- MinIO (S3) --
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# -- ClickHouse --
CLICKHOUSE_PASSWORD=clickhouse

# -- Airflow 3.x --
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=-7j9N20V-qkes3KfJMzeCS5SqJoTaOE67Zc1lBdm3Dk=
# Generate with: openssl rand -hex 32
AIRFLOW_API_SECRET=80a586d054463bb5cd1d986551fa8d6319d704c93f3f26348e9b5c81a057adb1
AIRFLOW_JWT_SECRET=80a586d054463bb5cd1d986551fa8d6319d704c93f3f26348e9b5c81a057adb1
AIRFLOW_ADMIN_PASSWORD=admin
# On Linux, run `id -u` and put the result here. macOS/Windows: leave 50000.
AIRFLOW_UID=50000

# -- Superset --
SUPERSET_SECRET_KEY=80a586d054463bb5cd1d986551fa8d6319d704c93f3f26348e9b5c81a057adb1
SUPERSET_ADMIN_PASSWORD=admin
